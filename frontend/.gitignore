# If you use npm  → keep package-lock.json, ignore yarn.lock & pnpm-lock.yaml
# If you use yarn → keep yarn.lock, ignore the others
# ──────────────────────────────────────────────
yarn.lock
pnpm-lock.yaml
# package-lock.json   ← uncomment if you switch to yarn/pnpm

